---
import { getSiteCopy } from "../../content/site-copy";
import type { Locale } from "../../lib/i18n";
import type { SiteSettingsView } from "../../types/content";
import LanguageSwitch from "./LanguageSwitch.astro";

interface Props {
  locale: Locale;
  currentPath: string;
  siteSettings: SiteSettingsView;
}

const { locale, currentPath, siteSettings } = Astro.props;
const copy = getSiteCopy(locale);
const navLabel = "Main navigation";
const brandStatement = "Surface Engineering and Equipment Systems";
const homePath = locale === "zh" ? "/" : `/${locale}/`;
const isHomePage = currentPath === "/" || currentPath === "/ja/" || currentPath === "/en/";
---

<header class:list={["site-header", isHomePage && "site-header--home"]}>
  <nav class="navbar" id="navbar" aria-label={navLabel}>
    <div class="navbar__surface">
      <span class="navbar__surface-bar" aria-hidden="true"></span>
      <div class="navbar__inner">
        <a class="navbar-brand" href={homePath}>
          <span class="navbar-brand__logo-shell">
            <img
              class="navbar-brand__logo"
              src="/logo.png"
              alt="Dalian Boheng logo"
              width="567"
              height="283"
            />
          </span>
          <span class="navbar-brand__meta">
            <span class="navbar-brand__eyebrow">DALIAN BOHENG</span>
            <span class="navbar-brand__name">{siteSettings.companyName}</span>
            <span class="navbar-brand__statement">{brandStatement}</span>
          </span>
        </a>

        <button
          class="navbar-toggle"
          type="button"
          aria-expanded="false"
          aria-controls="site-nav-panel"
          data-nav-toggle
        >
          <span></span>
          <span></span>
          <span></span>
        </button>

        <div class="navbar-collapse" id="site-nav-panel" data-nav-panel>
          <div class="navbar__actions">
            <div class="navbar-nav">
              {
                copy.nav.map((item) => (
                  <a class="nav-link" href={item.href}>{item.label}</a>
                ))
              }
            </div>
            <LanguageSwitch currentLocale={locale} currentPath={currentPath} />
          </div>
        </div>
      </div>
    </div>
  </nav>
</header>
