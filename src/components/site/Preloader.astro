---
interface Props {
  locale: "zh" | "ja";
}

const { locale } = Astro.props;

const label = locale === "ja" ? "読み込み中..." : "加载中...";
---

<div class="preloader" id="preloader" aria-live="polite">
  <div class="preloader__inner">
    <div class="loader" aria-hidden="true"></div>
    <div class="loader-text">{label}</div>
  </div>
</div>
