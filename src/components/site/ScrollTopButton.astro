---
import type { Locale } from "../../lib/i18n";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const label =
  locale === "ja"
    ? "ページ上部へ戻る"
    : locale === "en"
      ? "Back to top"
      : "返回顶部";
---

<button class="scroll-top" id="scrollTop" aria-label={label} type="button">
  <span aria-hidden="true">↑</span>
</button>
