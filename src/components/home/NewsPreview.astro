---
import { getNewsUrl, type Locale } from "../../lib/i18n";

interface Props {
  locale?: Locale;
  actionLabel?: string;
  content: {
    eyebrow: string;
    title: string;
    items: Array<{ slug?: string; title: string; summary: string; meta: string }>;
  };
}

const {
  content,
  locale = "zh",
  actionLabel = locale === "ja" ? "Read more" : "Read more",
} = Astro.props;
---

<section class="section news-preview-shell" id="news">
  <div class="section__inner news-preview-layout">
    <div class="news-preview-lead" data-reveal>
      <p class="eyebrow">{content.eyebrow}</p>
      <h2 class="section__title">{content.title}</h2>
      <p class="section__subtitle">
        Track Boheng’s latest delivery updates, engineering progress, and product communications through a calmer,
        editorial-style news layout.
      </p>
    </div>

    <div class="news-grid news-grid--stacked">
      {
        content.items.map((item, index) => (
          <article class="news-card" data-reveal data-delay={`${(index + 1) * 100}`}>
            <span class="news-card__meta">{item.meta}</span>
            <h3>{item.title}</h3>
            <p>{item.summary}</p>
            {item.slug && (
              <a class="button button--ghost" href={getNewsUrl(item.slug, locale)}>
                {actionLabel}
              </a>
            )}
          </article>
        ))
      }
    </div>
  </div>
</section>
